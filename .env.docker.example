# Rayyan ASM — Docker Compose Environment Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (never commit .env) and fill in values, then run
# `docker compose up -d`.
#
# IMPORTANT: this file uses the SHORT variable names that docker-compose.yml
# itself substitutes (${DB_USER}, ${JWT_SECRET}, etc). docker-compose.yml
# translates these into the RAYYAN_<SECTION>_<KEY> names the Go app actually
# reads at runtime — you don't need to (and shouldn't) set RAYYAN_* vars here.
#
# If you're running the app natively without Docker Compose (`go run
# ./cmd/server`), use .env.example instead — that one has the RAYYAN_*
# names the app's config loader (Viper) reads directly.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Postgres) ────────────────────────────────────────────────────
DB_USER=rayyan
DB_PASSWORD=CHANGE_ME                    # openssl rand -base64 32
DB_NAME=rayyan_asm
DB_SSLMODE=disable                       # disable for the bundled dev `db` service;
                                          # require/verify-full if pointing at external Postgres

# ── Redis ─────────────────────────────────────────────────────────────────
# Sets both the bundled Redis container's --requirepass AND the value the
# app authenticates with — the two must match, which is why docker-compose.yml
# feeds both from this single var. Leaving this unset means Redis runs with
# no authentication at all, reachable on the host's 6379.
REDIS_PASSWORD=CHANGE_ME                 # openssl rand -base64 32

# ── Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME                     # >= 32 random bytes, e.g. openssl rand -base64 32
# Encrypts stored scan-credential secrets at rest. Leave unset only for local
# dev with no real credentials configured.
RAYYAN_AUTH_CREDENTIALKEY=

# ── App / Server ──────────────────────────────────────────────────────────
APP_ENVIRONMENT=production               # development | staging | production
APP_VERSION=dev
PORT=8080                                # host port the app is published on
LOG_LEVEL=info

# ── External APIs (optional) ───────────────────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
SECURITYTRAILS_API_KEY=
VIRUSTOTAL_API_KEY=
