# Rayyan ASM — Environment Variable Reference
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env (never commit .env) and fill in values.
# All variables follow the pattern RAYYAN_<SECTION>_<KEY> and override the
# corresponding field in config/config.yaml.
#
# SECRETS ROTATION PROCEDURE is documented inline for each secret.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
RAYYAN_APP_ENVIRONMENT=production        # development | staging | production
RAYYAN_APP_URL=https://asm.example.com   # Base URL used in generated links/emails

# ── Server ────────────────────────────────────────────────────────────────────
RAYYAN_SERVER_PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
RAYYAN_DATABASE_DRIVER=postgres          # sqlite | postgres
RAYYAN_DATABASE_HOST=localhost
RAYYAN_DATABASE_PORT=5432
RAYYAN_DATABASE_NAME=rayyan_asm
RAYYAN_DATABASE_USER=rayyan
RAYYAN_DATABASE_PASSWORD=CHANGE_ME       # See rotation notes below
RAYYAN_DATABASE_SSLMODE=require          # disable | require | verify-full

# DB PASSWORD ROTATION:
#   1. Create new password:  openssl rand -base64 32
#   2. In psql:              ALTER USER rayyan PASSWORD 'newpassword';
#   3. Update .env and restart the app.  Zero downtime if done during low traffic.
#   4. Revoke old password from any other connected clients.

# ── Redis (optional) ──────────────────────────────────────────────────────────
RAYYAN_REDIS_ENABLED=false
RAYYAN_REDIS_HOST=localhost
RAYYAN_REDIS_PORT=6379
RAYYAN_REDIS_PASSWORD=CHANGE_ME          # See rotation notes below

# REDIS PASSWORD ROTATION:
#   1. Generate:  openssl rand -base64 32
#   2. Set in Redis 6+:  CONFIG SET requirepass "newpassword"  (hot reload, no restart)
#   3. Update .env and restart the app.

# ── Authentication ────────────────────────────────────────────────────────────

# JWT_SECRET — signs all access tokens.  Must be ≥32 random bytes.
# Generate:  openssl rand -base64 48
RAYYAN_AUTH_JWTSECRET=CHANGE_ME

# JWT SECRET ROTATION:
#   Rolling rotation (zero forced logouts):
#     1. Generate a new secret (see above).
#     2. Deploy with both old + new accepted (requires code change to validate both).
#     3. After RAYYAN_AUTH_JWTEXPIRY elapses (default 24h) all live tokens use
#        the new secret.  Remove the old secret acceptance.
#   Hard rotation (all sessions invalidated immediately):
#     1. Set RAYYAN_AUTH_JWTSECRET to the new value and restart.
#     2. All existing tokens are immediately invalid — users must log in again.
#     3. Use hard rotation if tokens may have been compromised.

RAYYAN_AUTH_JWTEXPIRY=24h
RAYYAN_AUTH_REFRESHEXPIRY=168h

# CREDENTIAL_KEY — AES-256-GCM key used to encrypt stored tool credentials
# (API keys, SMTP passwords, cloud secrets).  Must be exactly 32 bytes, encoded
# as base64 or hex.
# Generate (base64):  openssl rand -base64 32
# Generate (hex):     openssl rand -hex 32
RAYYAN_AUTH_CREDENTIALKEY=CHANGE_ME

# CREDENTIAL KEY ROTATION:
#   ⚠ Changing this key WITHOUT re-encrypting stored credentials will make
#   all stored credentials unreadable.  Follow this procedure:
#     1. Export all credentials via GET /tool-credentials (admin endpoint).
#        The API returns plaintext values while the old key is active.
#     2. Set the new RAYYAN_AUTH_CREDENTIALKEY in .env.
#     3. Re-import credentials via POST /tool-credentials — they will be
#        re-encrypted with the new key.
#     4. Restart the app.
#   Automate steps 1–3 with scripts/rotate-credential-key.sh (see README).

# SMTP (used for email notifications — store password via the credential system,
# not directly here; these vars configure the default notification channel)
RAYYAN_NOTIFICATIONS_SMTP_HOST=smtp.example.com
RAYYAN_NOTIFICATIONS_SMTP_PORT=587
RAYYAN_NOTIFICATIONS_SMTP_USER=alerts@example.com
RAYYAN_NOTIFICATIONS_SMTP_PASSWORD=CHANGE_ME     # See rotation notes below
RAYYAN_NOTIFICATIONS_SMTP_FROM=alerts@example.com

# SMTP PASSWORD ROTATION:
#   1. Generate a new app password in your mail provider's admin UI
#      (prefer app-specific passwords over account passwords).
#   2. Update RAYYAN_NOTIFICATIONS_SMTP_PASSWORD and restart.
#   3. Revoke the old app password in the mail provider UI.
#   For notification configs stored in the DB (via /notification-configs API),
#   the SMTP password is encrypted with RAYYAN_AUTH_CREDENTIALKEY — update it
#   via PATCH /notification-configs/:id.

# ── External API Keys ─────────────────────────────────────────────────────────
# All optional.  Absent keys disable the corresponding enrichment source.

RAYYAN_EXTERNAL_SHODANAPIKEY=           # https://account.shodan.io/
RAYYAN_EXTERNAL_CENSYSAPIID=            # https://search.censys.io/account/api
RAYYAN_EXTERNAL_CENSYSAPISECRET=
RAYYAN_EXTERNAL_SECURITYTRAILSKEY=      # https://securitytrails.com/app/account/apikey
RAYYAN_EXTERNAL_VIRUSTOTALKEY=          # https://www.virustotal.com/gui/my-apikey
RAYYAN_EXTERNAL_HIBPAPIKEY=             # https://haveibeenpwned.com/API/Key

# EXTERNAL KEY ROTATION:
#   External keys are not encrypted at rest here (they live in the process
#   environment only).  Rotate by:
#     1. Generating a new key in the provider's dashboard.
#     2. Updating the value here and restarting.
#     3. Revoking the old key in the provider dashboard.
#   For keys stored via the tool-credential system (POST /tool-credentials),
#   they are encrypted with RAYYAN_AUTH_CREDENTIALKEY — rotate via the API.

# ── Logging ───────────────────────────────────────────────────────────────────
RAYYAN_LOG_LEVEL=info                    # debug | info | warn | error
RAYYAN_LOG_FORMAT=json                   # json | console

# ── General Security Notes ────────────────────────────────────────────────────
# • Use a secrets manager (HashiCorp Vault, AWS Secrets Manager, GCP Secret
#   Manager) instead of .env files in production.  Inject secrets at runtime
#   via the environment.
# • Set restrictive file permissions:  chmod 600 .env
# • Never commit .env, config/config.yaml with secrets, or go.sum to public
#   repositories.
# • Rotate all secrets if any team member with access leaves the organisation
#   or if a breach is suspected.
# • Use RAYYAN_APP_ENVIRONMENT=production to enable stricter runtime checks
#   (e.g. the server refuses to start if RAYYAN_AUTH_JWTSECRET is empty).
